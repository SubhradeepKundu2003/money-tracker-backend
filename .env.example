# =============================================================================
# Money Tracker — environment template. Copy to .env and fill in real values:
#   cp .env.example .env
# .env is gitignored; this template is safe to commit.
# Load it, then run the app:
#   Git Bash / WSL :  set -a; source .env; set +a;  java -jar target/money-tracker-backend-0.0.1-SNAPSHOT.jar
#   PowerShell     :  Get-Content .env | ? {$_ -match '^export '} | % { $kv=($_ -replace '^export ','') -split '=',2; [Environment]::SetEnvironmentVariable($kv[0],$kv[1].Trim('"')) }
# =============================================================================

# --- Profile -----------------------------------------------------------------
export SPRING_PROFILES_ACTIVE=prod

# --- Database ----------------------------------------------------------------
export DB_URL=jdbc:postgresql://localhost:5432/moneytracker
export DB_USERNAME=moneytracker
export DB_PASSWORD=change-me

# --- Security (REQUIRED) -----------------------------------------------------
# Must be >= 32 bytes; the app refuses to start otherwise.
export APP_JWT_SECRET=replace-with-a-random-secret-at-least-32-bytes-long
# Comma-separated real origins of your client. Never "*" in prod.
export APP_CORS_ORIGINS=https://your-app-domain.com

# --- Optional tuning (defaults shown) ----------------------------------------
export SERVER_PORT=8080
export APP_SESSION_TTL_MINUTES=60
export APP_REFRESH_TTL_DAYS=30

# --- FIRST RUN ONLY: create the schema, then comment back out ----------------
# export SPRING_JPA_HIBERNATE_DDL_AUTO=update
